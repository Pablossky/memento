<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp" android:layout_height="wrap_content"
    android:layout_weight="1"
    android:clickable="true" android:focusable="true"
    android:foreground="?attr/selectableItemBackground">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center" android:paddingVertical="6dp">
        <TextView android:id="@+id/tvDay"
            android:layout_width="32dp" android:layout_height="32dp"
            android:gravity="center" android:textSize="14sp" android:textColor="#1A1A1A" />
        <View android:id="@+id/viewDot"
            android:layout_width="6dp" android:layout_height="6dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_color_circle"
            android:visibility="invisible" />
    </LinearLayout>
</FrameLayout>
