<resources xmlns:tools="http://schemas.android.com/tools">    <!-- Główny motyw aplikacji -->
    <style name="Theme.Memento" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Kolory podstawowe (to naprawia błąd 0x0) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Kolory akcentowe -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Kolory tła i powierzchni -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorError">@color/error</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.Memento.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />

    <style name="Theme.Memento.AppBarOverlay"
        parent="ThemeOverlay.MaterialComponents.Dark.ActionBar" />
</resources>