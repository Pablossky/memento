<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Memento" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_variant</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorSecondaryVariant">@color/color_secondary_variant</item>
        <!-- colorSecondaryContainer is used by NavigationBarMenuView active indicator -->
        <item name="colorSecondaryContainer">@color/color_secondary</item>
        <item name="android:colorBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorError">@color/color_error</item>
        <item name="colorOnPrimary">@color/text_dark</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <item name="colorOnBackground">@color/text_dark</item>
        <item name="colorOnSurface">@color/text_dark</item>
        <item name="colorOnSecondaryContainer">@color/text_dark</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.Memento.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />
</resources>
